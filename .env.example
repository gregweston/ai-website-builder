ANTHROPIC_API_KEY=your-anthropic-api-key
PEXELS_API_KEY=your-pexels-api-key
PORT=3000

# Required: the class gallery is stored in Upstash Redis (see the REST API
# tab on your database's Upstash dashboard for these values).
UPSTASH_REDIS_REST_URL=your-upstash-redis-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# Optional: set both to require a login prompt for the whole site (keeps
# random visitors out). Leave unset for local development.
SITE_USERNAME=your-class-username
SITE_PASSWORD=your-class-password

# Optional: overrides the Claude model for page generation (defaults to
# claude-haiku-4-5 if unset). Bump to a stronger model like claude-sonnet-5
# for a class session doing more ambitious work (e.g. complex p5.js games).
ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: which image search provider to use — "pexels" (default) or
# "wikimedia". Pexels is a curated stock library, pre-filtered for general
# use. Wikimedia Commons has a much broader library (real people, landmarks,
# etc.) but isn't pre-curated for kid-safety — see src/wikimediaClient.js for
# the category-based filtering that mitigates this. No API key needed for
# Wikimedia; PEXELS_API_KEY is unused when this is set to "wikimedia".
IMAGE_PROVIDER=pexels
